{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Computer Education{% endblock %}</title>
    <link rel="stylesheet" href="{% static 'css/style.css' %}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* Define the variables used in your code */
        :root {
            --csc-blue: #003366;
            --csc-gold: #ffcc00;
            --footer-bg: #111;
        }
        /* Stats Bar - Professional Highlight */
        .stats-bar {
            display: flex;
            justify-content: space-around;
            background: var(--csc-blue);
            color: white;
            padding: 50px 10%;
            text-align: center;
        }
        .stat-item i { font-size: 2.5rem; color: var(--csc-gold); margin-bottom: 10px; }
        .stat-item h3 { font-size: 2rem; margin: 5px 0; }
        /* FOOTER STYLES */
        .main-footer {
            background-color: var(--footer-bg);
            color: #f0ec13;
            padding: 60px 10% 20px;
            margin-top: 50px;
        }
        .footer-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 40px;
            margin-bottom: 40px;
        }
        .footer-col h4 {
            color: var(--csc-gold);
            margin-bottom: 20px;
            text-transform: uppercase;
            font-size: 1.2rem;
            border-bottom: 2px solid var(--csc-gold);
            display: inline-block;
            padding-bottom: 5px;
        }
        .footer-col p, .footer-col ul { font-size: 0.9rem; color: #ccc; line-height: 1.8; }
        .footer-col ul { list-style: none; padding: 0; }
        .footer-col ul li { margin-bottom: 10px; }
        .footer-col ul li a { color: #ccc; text-decoration: none; transition: 0.3s; }
        .footer-col ul li a:hover { color: var(--csc-gold); padding-left: 5px; }

        .social-links { margin-top: 20px; }
        .social-links a {
            color: #fff;
            font-size: 1.5rem;
            margin-right: 15px;
            transition: 0.3s;
        }
        .social-links a:hover { color: var(--csc-gold); }
        .footer-bottom {
            text-align: center;
            border-top: 1px solid #333;
            padding-top: 20px;
            font-size: 0.8rem;
            color: #777;
        }
        /* About Section */
        .about-section1 {
            background-color: #FFF9E6; /* Light yellowish-beige */
            display: flex;
            padding: 60px 100px;
            gap: 40px;
            align-items: flex-start;
        }
        .founder-card1 img {
            width: 200px;
            border-radius: 10px;
            box-shadow: 0px 0px 15px 5px rgba(255, 204, 0, 0.6); /* Yellow glow effect */
        }
        .about-content1 h2 {
            font-size: 28px;
            color: #333;
            margin-bottom: 20px;
        }
        .about-content1 p {
            font-size: 16px;
            color: #444;
            line-height: 1.6;
            margin-bottom: 15px;
}
    </style>
</head>
<body>
    <header class="navbar">
        <div class="logo">
            <img src="{% static 'img/download.png' %}" alt="CSC Logo">
        </div>
        <nav>
            <ul class="nav-links">
                <li><a href="{% url 'about' %}">About</a></li>
                <li><a href="{% url 'courses' %}">Courses</a></li>
                <li><a href="{% url 'contact' %}">Contact</a></li>
                <li class="dropdown">
                    <a href="#" class="login-btn">Login</a>
                    <div class="dropdown-content">
                        <a href="{% url 'student_login' %}">Student Login</a>
                        <a href="{% url 'staff_login' %}">Staff Login</a>
                    </div>
                </li>
            </ul>
        </nav>
    </header>
    <section class="hero">
        <h1 class="main-title">{{ main_heading|default:"CSC COMPUTER SOFTWARE COLLEGE" }}</h1>
        <div class="subtitle-box">
            <h2 class="subtitle">{{ sub_heading|default:"BOON FOR MIDDLE CLASS" }}</h2>
        </div>
    </section>
    <section class="stats-bar">
        <div class="stat-item">
            <i class="fas fa-network-wired"></i>
            <h3>{{ branch_count|default:"400+" }}</h3>
            <p>Global Branches</p>
        </div>
        <div class="stat-item">
            <i class="fas fa-users"></i>
            <h3>50,000+</h3>
            <p>Successful Students</p>
        </div>
        <div class="stat-item">
            <i class="fas fa-check-double"></i>
            <h3>ISO 9001:2015</h3>
            <p>Certified Quality</p>
        </div>
    </section>
    <section class="about-section">
        <div class="founder-card">
            <img src="{% static 'img/images.jpg' %}" alt="Founder Image">
        </div>
        <div class="about-content">
            <h2>{{ about_title|default:"About the Founder" }}</h2>
            <p> Our founder, {{ founder_name|default:"Mr. T. Iyamperumal M.E" }}, envisioned creating a platform to bridge education and technology, focusing on innovation, excellence, and accessibility for all learners especially to reach middle class who cannot afford more money to spend for learning latest technologies.
            </p>
            <p>
                Over the years, CSC Computer Education has grown exponentially, boasting a network of **{{ branch_count|default:"400+" }} branches** across the globe. Our training centers are equipped with state-of-the-art infrastructure and the latest technologies, fostering an environment conducive to interactive learning. From school-going children to corporate professionals, CSC caters to diverse learners through a rich array of courses.
            </p>
        </div>
    </section>
   <section class="about-section1">
    <div class="about-content1">
        <h2>About the Branch Manager Tirupathur</h2>
        <p>
            Our founder, Mr. Santha Murthy, envisioned creating a platform to bridge education and technology, focusing on innovation, excellence, and accessibility for all learners especially to reach middle class who cannot afford more money to spend for learning latest technologies.
        </p>
        <p>
            Over the years, CSC Computer Education has grown exponentially, boasting a network of **one branches** across the globe. Our training centers are equipped with state-of-the-art infrastructure and the latest technologies, fostering an environment conducive to interactive learning. From school-going children to corporate professionals, CSC caters to diverse learners through a rich array of courses.
        </p>
    </div>
    <div class="founder-card1">
        <img src="{% static 'img/img.jpg' %}" alt="Founder Image">
    </div>
</section>
    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-col">
                <h4>About CSC</h4>
                <p>CSC Computer Education is a pioneer in IT training, providing high-quality computer education to the masses for over three decades.</p>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="{% url 'about' %}">Our History</a></li>
                    <li><a href="{% url 'courses' %}">Browse Courses</a></li>
                    <li><a href="#">Franchise Opportunity</a></li>
                    <li><a href="#">Verify Certificate</a></li>
                    <li><a href="{% url 'contact' %}">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Head Office</h4>
                <p><i class="fas fa-map-marker-alt" style="color:var(--csc-gold)"></i> Tirupathur, Tamil Nadu, India</p>
                <p><i class="fas fa-phone" style="color:var(--csc-gold)"></i> +91 98428 22352</p>
                <p><i class="fas fa-envelope" style="color:var(--csc-gold)"></i> csctpt25@gmail.com</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 CSC Computer Software College. All Rights Reserved.</p>
        </div>
    </footer>
</body>
</html>

staff_assignments_list.html

{% extends 'base.html' %}
{% block content %}
<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-success text-white p-4 rounded-top-4 d-flex justify-content-between align-items-center">
            <h2 class="h4 mb-0"><i class="fas fa-tasks me-2"></i> Submitted Assignments</h2>
            <span class="badge bg-light text-success">{{ assignments.count }} Submissions</span>
        </div>
        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-4">
                    <input type="text" id="assignmentSearch" class="form-control" placeholder="Search by student or title...">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Student Name</th>
                            <th class="py-3">Subject</th>
                            <th class="py-3">Assignment Title</th>
                            <th class="py-3">Date Submitted</th>
                            <th class="py-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody id="assignmentTableBody">
                        {% for assignment in assignments %}
                        <tr>
                            <td class="fw-bold text-primary">{{ assignment.student.name }}</td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark">
                                    {{ assignment.subject.name }}
                                </span>
                            </td>
                            <td>{{ assignment.title }}</td>
                            <td class="text-muted small">
                                <i class="far fa-calendar-alt me-1"></i> {{ assignment.uploaded_at|date:"d M Y" }}
                            </td>
                            <td class="text-center">
                                <a href="{{ assignment.assignment_file.url }}" class="btn btn-outline-success btn-sm px-3 rounded-pill" target="_blank">
                                    <i class="fas fa-download me-1"></i> View/Download
                                </a>
                            </td>
                        </tr>
                        {% empty %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                                <p>No assignments have been submitted yet.</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="mt-4">
                <a href="{% url 'staff_dashboard' %}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
<script>
    document.getElementById('assignmentSearch').addEventListener('keyup', function() {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll('#assignmentTableBody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(value) ? '' : 'none';
        });
    });
</script>
{% endblock %}

staff_attendance_report.html

	
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance History | Staff</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { margin: 0; font-family: 'Inter', sans-serif; background-color: #F3F4F6; color: #374151; }
        /* Navbar */
        .dashboard-nav { background-color: #059669; color: white; padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .back-btn { color: white; text-decoration: none; font-weight: 600; font-size: 14px; background: rgba(255,255,255,0.2); padding: 8px 16px; border-radius: 6px; transition: 0.3s;}
        .back-btn:hover { background: rgba(255,255,255,0.3); }
        /* Main Container */
        .container { max-width: 1000px; margin: 40px auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .header-section { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 2px solid #F3F4F6; padding-bottom: 15px;}
        .header-section h2 { margin: 0; color: #111827; }
        /* Data Table */
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #E5E7EB; }
        th { background-color: #F9FAFB; color: #4B5563; font-weight: 600; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; }
        td { font-size: 15px; }

        /* Table Row Hover Effect */
        tbody tr:hover { background-color: #F9FAFB; }
        /* Status Badges */
        .status-badge { padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: bold; display: inline-block; text-align: center; min-width: 70px;}
        .status-present { background-color: #D1FAE5; color: #065F46; }
        .status-absent { background-color: #FEE2E2; color: #DC2626; }
        .status-leave { background-color: #FEF3C7; color: #92400E; }
    </style>
</head>
<body>
    <header class="dashboard-nav">
        <h1 style="margin: 0; font-size: 20px;">Staff Portal</h1>
        <a href="{% url 'staff_dashboard' %}" class="back-btn">← Back to Dashboard</a>
    </header>
    <div class="container">
        <div class="header-section">
            <h2>Attendance History Log</h2>
            <p style="margin: 0; color: #6B7280; font-weight: 500;">Instructor: <span style="color: #111827;">{{ staff.name }}</span></p>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Student ID</th>
                    <th>Student Name</th>
                    <th>Course</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for record in records %}
                <tr>
                    <td><strong>{{ record.date|date:"M d, Y" }}</strong></td>
                    <td style="color: #6B7280;">{{ record.student.std_id }}</td>
                    <td style="font-weight: 500; color: #111827;">{{ record.student.name }}</td>
                    <td>{{ record.student.course }}</td>
                    <td>
                        {% if record.status == 'Present' %}
                            <span class="status-badge status-present">Present</span>
                        {% elif record.status == 'Absent' %}
                            <span class="status-badge status-absent">Absent</span>
                        {% else %}
                            <span class="status-badge status-leave">Leave</span>
                        {% endif %}
                    </td>
                </tr>
                {% empty %}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 40px; color: #6B7280;">
                        No attendance records found yet. Once you take attendance, it will appear here!
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>

 staff_dashboard.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Dashboard | Computer Education</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --staff-green: #059669;
            --staff-gradient: linear-gradient(135deg, #059669 0%, #064e3b 100%);
            --surface-bg: #f8fafc;
            --text-main: #064e3b;
            --student-blue: #0000CC;
            --student-blue-dark: #000099;
            --bg-gray: #f8fafc;
        }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--surface-bg);
            color: #1e293b;
        }
          /* Navigation */
        .navbar {
            background: linear-gradient(135deg, var(--student-blue) 0%, var(--student-blue-dark) 100%) !important;
            border-bottom: 3px solid #3333ff;
            padding: 1rem 0;
        }
        /* Hero Banner */
        .welcome-banner {
            background: var(--staff-gradient);
            border-radius: 24px;
            padding: 40px;
            color: white;
            margin-bottom: 30px;
            box-shadow: 0 10px 25px rgba(5, 150, 105, 0.2);
            position: relative;
        }
        /* Profile Mini-Card (Inside Banner) */
        .profile-glass {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .action-card {
            background: white;
            border: none;
            border-radius: 20px;
            padding: 25px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            height: 100%;
        }
        .action-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(5, 150, 105, 0.15);
        }
        .icon-circle {
            width: 50px;
            height: 50px;
            background: #ecfdf5;
            color: var(--staff-green);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 15px;
        }
        .course-link {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-decoration: none;
            color: var(--text-main);
            font-weight: 600;
            transition: all 0.2s;
            margin-bottom: 12px;
        }
        .course-link:hover {
            background: var(--staff-green);
            color: white;
            transform: scale(1.02);
        }
        .btn-staff {
            background: var(--staff-gradient);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
        }
        .btn-staff:hover { color: white; opacity: 0.9; }
        .profile-detail { display: flex; justify-content: space-between; font-size: 0.9rem; padding: 5px 0; }
    </style>
</head>
<body>
        <nav class="navbar navbar-dark shadow-sm mb-5">
        <div class="container">
            <span class="navbar-brand fw-bold mb-0">
                <i class="fas fa-graduation-cap me-2"></i> Staff Portal
            </span>
            <a href="{% url 'staff_logout' %}" class="btn btn-light btn-sm fw-bold px-4 rounded-pill text-primary">
                Log Out
            </a>
        </div>
    </nav>
    <div class="container mt-4 pb-5">

        <div class="welcome-banner row align-items-center g-0">
            <div class="col-md-7 mb-4 mb-md-0">
                <h1 class="fw-bold display-6">Welcome, {{ staff.name }}</h1>
                <p class="opacity-75">You have {{ courses.count }} active batches to manage today.</p>
                <div class="mt-3">
                    <span class="badge bg-white text-success px-3 py-2 rounded-pill">
                        <i class="fas fa-check-circle me-1"></i> Verified Instructor
                    </span>
                </div>
            </div>
            <div class="col-md-5">
                <div class="profile-glass">
                    <h6 class="fw-bold mb-3"><i class="fas fa-id-card me-2"></i> Quick Profile</h6>
                    <div class="profile-detail"><span>Staff Id:</span> <strong>{{ staff.staffid }}</strong></div>
                    <div class="profile-detail"><span>Contact:</span> <strong>{{ staff.contact }}</strong></div>
                    <div class="profile-detail"><span>Qualifaction:</span> <strong>{{ staff.Qualification }}</strong></div>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="action-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Active Batches</h5>
                        <i class="fas fa-users text-muted"></i>
                    </div>
                    <div class="course-list">
                        {% for course in courses %}
                            <a href="{% url 'take_attendance' course %}" class="course-link">
                                <span><i class="fas fa-book-reader me-2 opacity-50"></i> {{ course }}</span>
                                <i class="fas fa-arrow-right small"></i>
                            </a>
                        {% empty %}
                            <div class="text-center py-4 text-muted">No courses assigned.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="row g-4">
                    <div class="col-12">
                        <div class="action-card">
                            <div class="icon-circle"><i class="fas fa-history"></i></div>
                            <h5 class="fw-bold">Reports</h5>
                            <p class="text-muted small">Access full attendance logs for certification tracking.</p>
                            <a href="{% url 'staff_attendance_report' %}" class="btn btn-staff w-100">Attendance Report</a>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="action-card">
                            <div class="icon-circle"><i class="fas fa-cloud-download-alt"></i></div>
                            <h5 class="fw-bold">Assignments</h5>
                            <p class="text-muted small">Download and grade student work submissions.</p>
                            <a href="{% url 'staff_list_assignments' %}" class="btn btn-dark w-100">Review Student Work</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

stdlogin.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Login | Computer Education</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: #F3F4F6; /* Soft gray background */
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .login-card {
            background-color: #FFFFFF;
            width: 100%;
            max-width: 400px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05); /* Soft modern shadow */
            text-align: center;
        }
        .login-card h2 {
            margin: 0 0 10px;
            color: #111827;
            font-size: 24px;
            font-weight: 700;
        }
        .login-card p {
            margin: 0 0 30px;
            color: #6B7280;
            font-size: 14px;
        }
        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #374151;
            font-size: 14px;
            font-weight: 500;
        }
        .input-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #D1D5DB;
            border-radius: 8px;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.3s, box-shadow 0.3s;
            box-sizing: border-box;
        }
        .input-group input:focus {
            outline: none;
            border-color: #0000CC; /* Match your brand blue */
            box-shadow: 0 0 0 3px rgba(0, 0, 204, 0.1);
        }
        .login-btn {
            width: 100%;
            padding: 14px;
            background-color: #0000CC; /* Brand Blue */
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background-color 0.3s;
            margin-top: 10px;
        }
        .login-btn:hover {
            background-color: #000099;
        }
        .back-link {
            display: inline-block;
            margin-top: 20px;
            color: #6B7280;
            text-decoration: none;
            font-size: 14px;
        }
        .back-link:hover { color: #111827; }
    </style>
</head>
<body>
    <div class="login-card">
        {% if messages %}
    {% for message in messages %}
        <div style="background-color: #FEE2E2; color: #DC2626; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; font-weight: 600; text-align: left; border: 1px solid #F87171;">
            {{ message }}
        </div>
    {% endfor %}
{% endif %}
        <h2>Student Portal</h2>
        <p>Enter your credentials to access your courses.</p>
        <form action="" method="POST">
            {% csrf_token %}
            <div class="input-group">
                <label for="userid">User ID</label>
                <input type="text" id="userid" name="userid" placeholder="Enter your Student ID" required>
            </div>
            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="login-btn">Login to Dashboard</button>
        </form>
        <a href="{% url 'home' %}" class="back-link">← Back to Home</a>
    </div>
</body>
</html>

