<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Login | Computer Education</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0; padding: 0; font-family: 'Inter', sans-serif; background-color: #F3F4F6;
            display: flex; justify-content: center; align-items: center; height: 100vh;
        }
        .login-card {
            background-color: #FFFFFF; width: 100%; max-width: 400px; padding: 40px;
            border-radius: 12px; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05); text-align: center;
        }
        .login-card h2 { margin: 0 0 10px; color: #111827; font-size: 24px; font-weight: 700; }
        .login-card p { margin: 0 0 30px; color: #6B7280; font-size: 14px; }
        /* Error message styling */
        .alert-message {
            background-color: #FEE2E2; color: #DC2626; padding: 12px; border-radius: 8px;
            margin-bottom: 20px; font-size: 14px; font-weight: 600; text-align: left; border: 1px solid #F87171;
        }
        .input-group { text-align: left; margin-bottom: 20px; }
        .input-group label { display: block; margin-bottom: 8px; color: #374151; font-size: 14px; font-weight: 500; }
        .input-group input {
            width: 100%; padding: 12px 16px; border: 1px solid #D1D5DB; border-radius: 8px;
            font-size: 15px; font-family: 'Inter', sans-serif; transition: 0.3s; box-sizing: border-box;
        }
        .input-group input:focus {
            outline: none; border-color: #059669; /* Staff Green */
            box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.1);
        }
        .login-btn {
            width: 100%; padding: 14px; background-color: #059669; color: white;
            border: none; border-radius: 8px; font-size: 16px; font-weight: 600; font-family: 'Inter', sans-serif;
            cursor: pointer; transition: 0.3s; margin-top: 10px;
        }
        .login-btn:hover { background-color: #047857; }
        .back-link { display: inline-block; margin-top: 20px; color: #6B7280; text-decoration: none; font-size: 14px; }
        .back-link:hover { color: #111827; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>Staff Portal</h2>
        <p>Faculty and staff, please log in here.</p>
        {% if messages %}
            {% for message in messages %}
                <div class="alert-message">
                    {{ message }}
                </div>
            {% endfor %}
        {% endif %}
        <form action="{% url 'staff_login_val' %}" method="POST">
            {% csrf_token %}
            <div class="input-group">
                <label for="userid">Staff ID</label>
                <input type="text" id="userid" name="userid" placeholder="Enter your Staff ID" required>
            </div>
            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="login-btn">Secure Login</button>
        </form>
        <a href="{% url 'home' %}" class="back-link">← Back to Home</a>
    </div>
</body>
</html>

student_dashboard.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Computer Education</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --student-blue: #0000CC;
            --student-blue-dark: #000099;
            --bg-gray: #f8fafc;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-gray);
            color: #1e293b;
        }
        /* Navigation */
        .navbar {
            background: linear-gradient(135deg, var(--student-blue) 0%, var(--student-blue-dark) 100%) !important;
            border-bottom: 3px solid #3333ff;
            padding: 1rem 0;
        }
        /* Card Enhancements */
        .card {
            border: none;
            border-radius: 16px;
            background: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s ease;
            height: 100%;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .card h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        /* Data Rows */
        .data-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f1f5f9;
        }
        .data-row:last-child { border-bottom: none; }
        .data-label { color: #64748b; font-weight: 500; font-size: 0.9rem; }
        .data-value { color: #1e293b; font-weight: 600; font-size: 0.95rem; }
        /* Exam Section Specifics */
        .exam-section { border-top: 5px solid var(--student-blue); }
        .exam-link-btn {
            background-color: var(--student-blue);
            color: white;
            text-decoration: none;
            padding: 14px 30px;
            border-radius: 10px;
            font-weight: 700;
            display: inline-block;
            transition: all 0.3s ease;
            border: none;
            box-shadow: 0 4px 12px rgba(0, 0, 204, 0.2);
        }
        .exam-link-btn:hover {
            background-color: #1e293b;
            color: white;
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
        }
        /* Status Badges */
        .status-box {
            padding: 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 500;
        }
        .status-waiting { background: #fffbeb; color: #92400e; border: 1px solid #fef3c7; }
        /* Helpers */
        .text-student-blue { color: var(--student-blue); }
        .text-success-custom { color: #059669; }
        .text-danger-custom { color: #dc2626; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark shadow-sm mb-5">
        <div class="container">
            <span class="navbar-brand fw-bold mb-0">
                <i class="fas fa-graduation-cap me-2"></i> Student Portal
            </span>
            <a href="{% url 'student_logout' %}" class="btn btn-light btn-sm fw-bold px-4 rounded-pill text-primary">
                Log Out
            </a>
        </div>
    </nav>
   <div class="container pb-5">
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card p-4">
                    <h2><i class="fas fa-user-circle text-student-blue"></i> Academic Profile</h2>
                    <div class="data-row">
                        <span class="data-label">Name</span>
                        <span class="data-value">{{ student.name }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Student ID</span>
                        <span class="data-value">{{ student.std_id }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Course</span>
                        <span class="data-value text-student-blue">{{ student.course }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Batch Timing</span>
                        <span class="data-value">{{ student.timing }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card p-4">
                    <h2><i class="fas fa-calendar-check text-student-blue"></i> Attendance Record</h2>
                    <div class="data-row">
                        <span class="data-label">Total Classes Held</span>
                        <span class="data-value">{{ student.total_classes }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Days Present</span>
                        <span class="data-value">{{ student.days_present }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Overall Percentage</span>
                        <span class="data-value">
                            {% if student.attendance_percentage >= 75 %}
                                <span class="text-success-custom">{{ student.attendance_percentage }}%</span>
                            {% else %}
                                <span class="text-danger-custom">{{ student.attendance_percentage }}%</span>
                            {% endif %}
                        </span>
                    </div>
                    <p class="mt-3 text-muted small italic mb-0">
                        * Maintain above 75% for certification eligibility.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card p-4">
                    <h2><i class="fas fa-wallet text-student-blue"></i> Fee Status</h2>
                    <div class="data-row">
                        <span class="data-label">Total Course Fee</span>
                        <span class="data-value">₹{{ student.fees }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Amount Paid</span>
                        <span class="data-value text-success-custom">₹{{ student.fees_paid }}</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">Remaining Balance</span>
                        <span class="data-value">
                            {% if student.remaining > 0 %}
                                <span class="text-danger-custom fw-bold">₹{{ student.remaining }}</span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success border border-success">Cleared</span>
                            {% endif %}
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card exam-section p-4">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <h2><i class="fas fa-file-signature text-student-blue"></i> Examination Portal</h2>
                            {% if assigned_exam %}
                                <div class="mb-4">
                                    <h3 class="h5 mb-1">{{ assigned_exam.title }}</h3>
                                    <p class="text-muted small mb-0">
                                        <i class="fas fa-book me-1"></i> {{ assigned_exam.course_name }} |
                                        <i class="fas fa-clock ms-2 me-1"></i> Scheduled: {{ assigned_exam.scheduled_date }}
                                    </p>
                                </div>
                                {% if assigned_exam.is_active %}
                                    <div class="d-flex align-items-center gap-3">
                                        <p class="text-success-custom fw-bold mb-0">
                                            <i class="fas fa-broadcast-tower fa-beat me-2"></i> Exam is LIVE
                                        </p>
                                        <a href="{{ assigned_exam.exam_link }}" target="_blank" class="exam-link-btn">
                                            START ONLINE EXAM
                                        </a>
                                    </div>
                                {% else %}
                                    <div class="status-box status-waiting">
                                        <i class="fas fa-hourglass-half me-2"></i> The exam is assigned but not yet active. Please wait for your instructor to start the session.
                                    </div>
                                {% endif %}
                            {% else %}
                                <div class="text-muted py-3">
                                    <i class="fas fa-info-circle me-2"></i> No exams are currently assigned to your profile.
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-lg-4 d-none d-lg-block text-center text-muted">
                            <i class="fas fa-user-graduate fa-5x opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card p-4">
                    <div>
                        <h2><i class="fas fa-upload text-student-blue"></i> Assignment Submission</h2>
                        <p class="text-muted small mb-3">Submit your assignments here. Ensure you follow the guidelines provided by your instructor.</p>
                        <p>Subject: Python Programming</p>
                        <a href="{% url 'student_upload_assignment' %}" class="btn btn-primary w-100 mt-3">
                            <i class="fas fa-upload me-2"></i> Upload New Assignment
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

student_upload.html

{% extends 'base.html' %} {% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h2 class="h4 mb-0"><i class="fas fa-file-upload me-2"></i> Upload Assignment</h2>
                </div>
                <div class="card-body p-4">
                    {% if messages %}
                        {% for message in messages %}
                            <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        {% endfor %}
                    {% endif %}
                    <form method="POST" enctype="multipart/form-data">
                        {% csrf_token %}

                        <div class="mb-3">
                            <label class="form-label fw-bold">Assignment Title</label>
                            <input type="text" name="title" class="form-control form-control-lg" placeholder="e.g. Python Loops Exercise" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select Subject</label>
                            <select name="subject" class="form-select">
                                <option value="" selected disabled>Choose your subject...</option>
                                {% for sub in subjects %}
                                    <option value="{{ sub.id }}">{{ sub.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Select Assignment File</label>
                            <input type="file" name="assignment_file" class="form-control" required>
                            <div class="form-text">Accepted formats: PDF, DOCX, ZIP, or Images.</div>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                <i class="fas fa-paper-plane me-2"></i> Submit Assignment
                            </button>
                            <a href="{% url 'student_dashboard' %}" class="btn btn-outline-secondary">
                                Back to Dashboard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

 take_attendence.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Take Attendance | Staff</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { margin: 0; font-family: 'Inter', sans-serif; background-color: #F3F4F6; }
        .dashboard-nav { background-color: #059669; color: white; padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; }
        .container { max-width: 900px; margin: 40px auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #E5E7EB; }
        th { background-color: #F9FAFB; color: #374151; }
        .radio-group { display: flex; gap: 15px; }
        .radio-group label { cursor: pointer; font-size: 14px; display: flex; align-items: center; gap: 5px; }
        .submit-btn {
            background-color: #059669; color: white; border: none; padding: 12px 24px;
            border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 20px; width: 100%; font-size: 16px;
        }
        .submit-btn:hover { background-color: #047857; }
        .back-link { display: inline-block; margin-bottom: 20px; color: #6B7280; text-decoration: none; font-weight: bold;}
    </style>
</head>
<body>
    <header class="dashboard-nav">
        <h1 style="margin: 0; font-size: 20px;">Staff Portal</h1>
        <a href="{% url 'staff_dashboard' %}" style="color: white; text-decoration: none; font-weight: bold;">← Back to Dashboard</a>
    </header>
    <div class="container">
        <a href="{% url 'staff_dashboard' %}" class="back-link">← Back to Dashboard</a>
        <h2 style="margin-top: 0;">Attendance for: <span style="color: #059669;">{{ course_name }}</span></h2>
        <form method="POST">
            {% csrf_token %}
            <div style="margin-bottom: 20px;">
                <label style="font-weight: bold;">Date:</label>
                <input type="date" name="attendance_date" value="{{ today }}" style="padding: 8px; border-radius: 5px; border: 1px solid #ccc;">
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Name</th>
                        <th>Timing</th>
                        <th>Mark Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for student in students %}
                    <tr>
                        <td>{{ student.std_id }}</td>
                        <td><strong>{{ student.name }}</strong></td>
                        <td>{{ student.timing }}</td>
                        <td>
                            <div class="radio-group">
                                <label><input type="radio" name="status_{{ student.std_id }}" value="Present" required> Present</label>
                                <label><input type="radio" name="status_{{ student.std_id }}" value="Absent"> Absent</label>
                                <label><input type="radio" name="status_{{ student.std_id }}" value="Leave"> Leave</label>
                            </div>
                        </td>
                    </tr>
                    {% empty %}
                    <tr>
                        <td colspan="4" style="text-align: center; color: #DC2626;">No students found for this course.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% if students %}
                <button type="submit" class="submit-btn">Save Attendance</button>
            {% endif %}
        </form>
    </div>
</body>
</html>

