{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Computer Education</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* --- Base Theme Variables --- */
        :root {
            --primary-blue: #0000CC;
            --csc-gold: #FFCC00;
            --bg-light: #F9FAFB;
            --footer-bg: #111827;
        }
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            color: #374151;
            overflow-x: hidden;
        }
        /* --- 1. FIXED NAVBAR --- */
        .navbar {
            background-color: var(--csc-gold);
            padding: 0 50px;
            height: 75px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 2000;
        }
        .nav-links { list-style: none; display: flex; gap: 30px; align-items: center; margin: 0; padding: 0;}
        .nav-links li a {
            text-decoration: none;
            color: var(--primary-blue);
            font-weight: 800;
            font-size: 15px;
            transition: 0.3s;
        }
        .nav-links li a:hover { color: #000; }
        .login-btn-nav {
            background-color: var(--primary-blue);
            color: white !important;
            padding: 10px 20px;
            border-radius: 5px;
        }
        /* --- 2. AUTO-SLIDER SECTION --- */
        .slider-wrapper {
            position: relative;
            width: 100%;
            height: 500px;
            overflow: hidden;
            background-color: #000;
            z-index: 10;
        }
        .slide {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0;
            transition: opacity 1.2s ease-in-out;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .slide.active { opacity: 1; z-index: 20; }
        .slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.45);
        }
        .slide-text {
            position: absolute;
            z-index: 100;
            text-align: center;
            color: white;
            padding: 0 20px;
        }
        .slide-text h1 { font-size: 55px; margin: 0; font-weight: 800; text-shadow: 2px 2px 15px rgba(0,0,0,0.6); }
        .slide-text p { font-size: 24px; margin-top: 10px; opacity: 0.9; }
        /* --- 3. MAIN CONTENT CONTAINER --- */
        .container { max-width: 1100px; margin: 60px auto; padding: 0 20px; }
        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
            margin-bottom: 80px;
        }
        .text-block h2 { color: var(--primary-blue); font-size: 34px; font-weight: 800; margin-top: 0; margin-bottom: 25px; }
        .text-block p { font-size: 17px; line-height: 1.8; color: #4B5563; margin-bottom: 20px; }
        .highlight-motto {
            font-size: 24px; color: #111827; font-weight: 700;
            border-left: 6px solid var(--csc-gold); padding-left: 20px; margin: 40px 0;
        }
        /* --- 4. FEATURED COURSES --- */
        .course-summary-section {
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 5px 30px rgba(0,0,0,0.05);
        }
        .course-summary-section h2 { text-align: center; font-size: 32px; margin-bottom: 45px; }
        .mini-course-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
        .mini-course-card {
            border: 1px solid #F3F4F6;
            border-radius: 12px;
            padding: 30px;
            transition: 0.3s ease;
            border-top: 5px solid var(--primary-blue);
            background: #FFF;
        }
        .mini-course-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); border-top-color: var(--csc-gold); }
        /* --- 5. ALBUMS / GALLERY (GREEN THEME) --- */
        .album-section {
            padding: 80px 0;
            margin-top: 80px;
        }
        .rainbow-title {
            font-size: 60px;
            font-weight: 900;
            text-align: center;
            margin-bottom: 50px;
            background: linear-gradient(to right, #6a11cb, #2575fc, #00ff00, #ffff00, #ff7f00, #ff0000);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .gallery-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            padding: 0 8%;
            justify-items: center;
        }
        .card {
            background: #000;
            border: 3px solid #ff4500; /* Glowing Orange-Red border */
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 0 30px rgba(0, 0, 0, 0.5);
            width: 320px;
            height: 420px;
            transition: 0.3s;
        }
        .card:hover { transform: scale(1.04); }
        .card video, .card img { width: 100%; height: 100%; object-fit: cover; }
        /* --- 6. FOOTER --- */
        .main-footer {
            background-color: var(--footer-bg);
            color: #D1D5DB;
            padding: 80px 8% 30px;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 50px;
            margin-bottom: 50px;
        }
        .footer-col h4 { color: var(--csc-gold); font-size: 20px; margin-bottom: 25px; text-transform: uppercase; }
        .footer-col ul { list-style: none; padding: 0; }
        .footer-col ul li { margin-bottom: 15px; }
        .footer-col a { color: #9CA3AF; text-decoration: none; transition: 0.3s; }
        .footer-col a:hover { color: var(--csc-gold); padding-left: 8px; }
        .footer-contact i { color: var(--csc-gold); margin-right: 12px; }
        .footer-bottom {
            text-align: center; border-top: 1px solid #374151;
            padding-top: 30px; font-size: 14px; color: #6B7280;
        }
        /* --- Mobile Responsive --- */
        @media (max-width: 768px) {
            .details-grid { grid-template-columns: 1fr; }
            .navbar { height: auto; flex-direction: column; padding: 20px; }
            .nav-links { margin-top: 15px; flex-wrap: wrap; justify-content: center; }
            .slider-wrapper { height: 350px; }
            .slide-text h1 { font-size: 34px; }
            .rainbow-title { font-size: 40px; }
        }
    </style>
</head>
<body>
    <header class="navbar">
        <h2 style="color: var(--primary-blue); margin: 0; font-weight: 800; letter-spacing: -1px;">COMPUTER EDUCATION</h2>
        <ul class="nav-links">
            <li><a href="{% url 'home' %}">Home</a></li>
            <li><a href="{% url 'courses' %}">Courses</a></li>
            <li><a href="{% url 'contact' %}">Contact</a></li>
            <li><a href="{% url 'student_login' %}" class="login-btn-nav">Student Login</a></li>
        </ul>
    </header>
    <div class="slider-wrapper">
        <div class="slide-text">
            <h1>Transforming Lives Through IT</h1>
            <p>Welcome to CSC Tirupattur Branch</p>
        </div>
        <div class="slide active"><img src="{% static 'img/slider1.jpeg' %}" alt="Campus 1"></div>
        <div class="slide"><img src="{% static 'img/slider2.jpeg' %}" alt="Campus 2"></div>
        <div class="slide"><img src="{% static 'img/slider3.jpeg' %}" alt="Campus 3"></div>
        <div class="slide"><img src="{% static 'img/slider4.jpeg' %}" alt="Campus 4"></div>
        <div class="slide"><img src="{% static 'img/slider5.jpeg' %}" alt="Campus 5"></div>
        <div class="slide"><img src="{% static 'img/slider6.jpeg' %}" alt="Campus 6"></div>
    </div>

    <div class="container">
        <div class="details-grid">
            <div class="text-block">
                <h2>Our Vision</h2>
                <p>Founded under the visionary leadership of Mr. T. Iyamperumal M.E, CSC Computer Education has been at the forefront of providing industry-relevant IT training across India.</p>
                <div class="highlight-motto">"A True Boon for the Middle Class"</div>
                <p>We believe that financial constraints should never stand in the way of ambition. Our Tirupattur branch carries forward this legacy by offering top-tier training at affordable fees.</p>
            </div>
            <div class="text-block">
                <h2>Excellence in Training</h2>
                <p>With over 35 years of educational history, we provide ISO 9001:2015 certified training programs. Our labs are equipped with the latest software infrastructure to ensure hands-on learning.</p>
                <p>Our faculty members are dedicated mentors who guide students from basic computer literacy to advanced full-stack development and programming languages.</p>
            </div>
        </div>
        <div class="course-summary-section">
            <h2>Featured Courses</h2>
            <div class="mini-course-grid">
                {% for course in courses %}
                    <div class="mini-course-card">
                        <span style="color: var(--primary-blue); font-weight: bold; font-size: 14px;">⏱ {{ course.duration }}</span>
                        <h4 style="margin: 10px 0;">{{ course.name }}</h4>
                        <p style="font-size: 14px; color: #6B7280; margin: 0;">{{ course.content|truncatewords:12 }}</p>
                    </div>
                {% empty %}
                    <p style="grid-column: 1/-1; text-align: center;">Course information is being updated...</p>
                {% endfor %}
            </div>
            <div style="text-align: center; margin-top: 40px;">
                <a href="{% url 'courses' %}" style="text-decoration: none; background: var(--primary-blue); color: white; padding: 12px 30px; border-radius: 6px; font-weight: bold;">Browse All Courses</a>
            </div>
        </div>
    </div>
    <div class="album-section">
        <h1 class="rainbow-title">ALBUMS</h1>
        <div class="gallery-container">
            <div class="card"><video controls><source src="{% static 'img/video1.mp4' %}" type="video/mp4"></video></div>
            <div class="card"><video controls><source src="{% static 'img/video2.mp4' %}" type="video/mp4"></video></div>
            <div class="card"><video controls><source src="{% static 'img/video3.mp4' %}" type="video/mp4"></video></div>
            <div class="card"><img src="{% static 'img/img1.jpeg' %}" alt="Gallery 1"></div>
            <div class="card"><img src="{% static 'img/img2.jpeg' %}" alt="Gallery 2"></div>
            <div class="card"><img src="{% static 'img/img3.jpeg' %}" alt="Gallery 3"></div>
        </div>
    </div>
    <footer class="main-footer">
        <div class="footer-grid">
            <div class="footer-col">
                <h4>CSC Tirupattur</h4>
                <p>Empowering the community through affordable and high-quality IT education since 1998. ISO 9001:2015 Certified Institution.</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="{% url 'home' %}">Home</a></li>
                    <li><a href="{% url 'courses' %}">Our Courses</a></li>
                    <li><a href="{% url 'contact' %}">Contact Us</a></li>
                    <li><a href="#">Verify Certificate</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Reach Us</h4>
                <p><i class="fas fa-map-marker-alt"></i> Tirupattur Main Road, TN</p>
                <p><i class="fas fa-phone-alt"></i> +91 98765 43210</p>
                <p><i class="fas fa-envelope"></i>csctpt25@gmail.com</p>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 CSC Computer Education. All Rights Reserved.
        </div>
    </footer>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const slides = document.querySelectorAll('.slide');
            let currentSlide = 0;
            function nextSlide() {
                slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                slides[currentSlide].classList.add('active');
            }
            setInterval(nextSlide, 3800); // 3.8 seconds per slide
        });
    </script>
</body>
</html>

 adminlogin.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | CSC Computer Education</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0; padding: 0; font-family: 'Inter', sans-serif; background-color: #E5E7EB; /* Slightly darker background for admin */
            display: flex; justify-content: center; align-items: center; height: 100vh;
        }
        .login-card {
            background-color: #FFFFFF; width: 100%; max-width: 400px; padding: 40px;
            border-radius: 12px; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1); /* Deeper shadow */ text-align: center;
        }
        .login-card h2 { margin: 0 0 10px; color: #111827; font-size: 24px; font-weight: 700; }
        .login-card p { margin: 0 0 30px; color: #6B7280; font-size: 14px; }
        .input-group { text-align: left; margin-bottom: 20px; }
        .input-group label { display: block; margin-bottom: 8px; color: #374151; font-size: 14px; font-weight: 600; }
        .input-group input {
            width: 100%; padding: 12px 16px; border: 1px solid #D1D5DB; border-radius: 8px;
            font-size: 15px; font-family: 'Inter', sans-serif; transition: 0.3s; box-sizing: border-box;
        }
        .input-group input:focus {
            outline: none; border-color: #111827; /* Admin Black */
            box-shadow: 0 0 0 3px rgba(17, 24, 39, 0.1);
        }
        .login-btn {
            width: 100%; padding: 14px; background-color: #111827; /* Admin Black */ color: white;
            border: none; border-radius: 8px; font-size: 16px; font-weight: 600; font-family: 'Inter', sans-serif;
            cursor: pointer; transition: 0.3s; margin-top: 10px;
        }
        .login-btn:hover { background-color: #374151; }
        .back-link { display: inline-block; margin-top: 20px; color: #6B7280; text-decoration: none; font-size: 14px; }
        .back-link:hover { color: #111827; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>System Administrator</h2>
        <p>Restricted access. Authorized personnel only.</p>
        <form action="" method="POST">
            {% csrf_token %}
            <div class="input-group">
                <label for="userid">Admin ID</label>
                <input type="text" id="userid" name="userid" placeholder="Enter Admin ID" required>
            </div>
            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter password" required>
            </div>
            <button type="submit" class="login-btn">Login as Admin</button>
        </form>
        <a href="{% url 'home' %}" class="back-link">← Back to Home</a>
    </div>
</body>
</html>

